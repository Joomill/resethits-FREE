<?xml version="1.0" encoding="utf-8"?>
<extension type="module" client="administrator" method="upgrade" position="cpanel">
    <name>MOD_RESETHITS</name>
    <description>MOD_RESETHITS_XML_DESCRIPTION</description>
    <author>Jeroen Moolenschot | Joomill</author>
    <authorEmail>info@joomill.nl</authorEmail>
    <authorUrl>https://www.joomill-extensions.com</authorUrl>
    <license>GNU General Public License version 3 or later</license>
    <creationDate>June 2026</creationDate>
    <copyright>(C) 2026 Joomill Extensions</copyright>
    <version>5.1.1</version>
    <namespace path="src">Joomill\Module\Resethits</namespace>

    <!-- Files -->
    <files>
        <folder>language</folder>
        <folder module="mod_resethits">services</folder>
        <folder>src</folder>
        <folder>tmpl</folder>
    </files>

    <!-- Scripts to run on installation -->
    <scriptfile>script.php</scriptfile>

    <!-- Config -->
    <config>
        <fields name="params" addfieldprefix="Joomill\Module\Resethits\Administrator\Field">
            <fieldset name="basic">
                <field
                        name="articlehits"
                        type="radio"
                        label="MOD_RESETHITS_ARTICLE_HITS_TITLE"
                        layout="joomla.form.field.radio.switcher"
                        default="1"
                        filter="integer"
                >
                    <option value="0">JHIDE</option>
                    <option value="1">JSHOW</option>
                </field>
                <field
                        name="articlerevisions"
                        type="radio"
                        label="MOD_RESETHITS_ARTICLE_REVISIONS_TITLE"
                        layout="joomla.form.field.radio.switcher"
                        default="1"
                        filter="integer"
                >
                    <option value="0">JHIDE</option>
                    <option value="1">JSHOW</option>
                </field>
                <field
                        name="bannerimpressions"
                        type="radio"
                        label="MOD_RESETHITS_BANNER_IMPRESSIONS_TITLE"
                        layout="joomla.form.field.radio.switcher"
                        default="1"
                        filter="integer"
                >
                    <option value="0">JHIDE</option>
                    <option value="1">JSHOW</option>
                </field>
                <field
                        name="bannerclicks"
                        type="radio"
                        label="MOD_RESETHITS_BANNER_CLICKS_TITLE"
                        layout="joomla.form.field.radio.switcher"
                        default="1"
                        filter="integer"
                >
                    <option value="0">JHIDE</option>
                    <option value="1">JSHOW</option>
                </field>
                <field
                        name="userpassword"
                        type="radio"
                        label="MOD_RESETHITS_USER_PASSWORD_TITLE"
                        layout="joomla.form.field.radio.switcher"
                        default="1"
                        filter="integer"
                >
                    <option value="0">JHIDE</option>
                    <option value="1">JSHOW</option>
                </field>
                <field
                        name="redirects"
                        type="radio"
                        label="MOD_RESETHITS_REDIRECTS_TITLE"
                        layout="joomla.form.field.radio.switcher"
                        default="1"
                        filter="integer"
                >
                    <option value="0">JHIDE</option>
                    <option value="1">JSHOW</option>
                </field>
            </fieldset>
            <fieldset name="pro" label="MOD_RESETHITS_PRO_FILTERS_LABEL">
                <field
                        name="pro_filter_articles"
                        type="pro"
                        label="MOD_RESETHITS_PRO_FILTER_ARTICLES_LABEL"
                        description="MOD_RESETHITS_PRO_FILTER_ARTICLES_DESC"
                />
                <field
                        name="pro_filter_banners"
                        type="pro"
                        label="MOD_RESETHITS_PRO_FILTER_BANNERS_LABEL"
                        description="MOD_RESETHITS_PRO_FILTER_BANNERS_DESC"
                />
                <field
                        name="pro_filter_users"
                        type="pro"
                        label="MOD_RESETHITS_PRO_FILTER_USERS_LABEL"
                        description="MOD_RESETHITS_PRO_FILTER_USERS_DESC"
                />
            </fieldset>
            <fieldset name="advanced">
                <field
                        name="layout"
                        type="modulelayout"
                        label="JFIELD_ALT_LAYOUT_LABEL"
                        class="form-select"
                />
                <field
                        name="header_icon"
                        type="text"
                        label="Header Icon"
                        default="fa-solid fa-arrow-rotate-left"
                />
                <field
                        type="editor"
                        name="custom_css"
                        label="MOD_RESETHITS_CUSTOM_CSS_LABEL"
                        default=""
                        rows="10"
                        buttons="no"
                        editor="codemirror|none"
                        filter="raw"
                />
                <field
                        name="hrreview"
                        type="spacer"
                        hr="true"
                />
                <field
                        name="notereview"
                        type="note"
                        label="MOD_RESETHITS_REVIEW_LABEL"
                        description="MOD_RESETHITS_REVIEW_DESC"
                        class="alert alert-success"
                />
            </fieldset>
        </fields>
    </config>

    <!-- Help button URL -->
    <help key="" url="MOD_RESETHITS_HELP_URL" />

    <!-- Changelog -->
    <changelogurl>
        <![CDATA[https://www.joomill-extensions.com/index.php?option=com_ochsubscriptions&amp;view=changelog&amp;format=xml&amp;cat=2]]>
    </changelogurl>

    <!-- Update servers -->
    <updateservers>
        <server type="extension" name="Reset Hits">
            <![CDATA[https://www.joomill-extensions.com/index.php?option=com_ochsubscriptions&amp;view=updater&amp;format=xml&amp;cat=2]]>
        </server>
    </updateservers>
</extension>
